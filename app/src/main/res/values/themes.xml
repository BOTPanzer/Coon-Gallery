<resources>
    <style name="Theme.TurboPhotos" parent="Theme.Material3Expressive.Light.NoActionBar">
        <!-- Status bar color -->
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Navigation bar color -->
        <item name="android:navigationBarColor">?attr/colorSurface</item>

        <!-- Modals -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.TurboPhotos.AlertDialog</item>

        <!-- Default font -->
        <item name="android:fontFamily">@font/poppins</item>
    </style>

    <!-- EditText -->
    <style name="EditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:textCursorDrawable">@drawable/custom_cursor</item>
        <item name="android:textColorPrimary">?attr/colorOnPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textColorSecondary">?attr/colorOnSecondary</item>
        <item name="android:textColorHint">?attr/colorOnSecondary</item>
        <item name="android:textColorHighlight">?attr/colorOnSecondary</item>
    </style>

    <!-- Modals -->
    <style name="TextAppearance.TurboPhotos.Dialog.Title" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="TextAppearance.TurboPhotos.Dialog.Content" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="ThemeOverlay.TurboPhotos.AlertDialog" parent="ThemeOverlay.Material3Expressive.MaterialAlertDialog">
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.TurboPhotos.Dialog.Title</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.TurboPhotos.Dialog.Content</item>
        <item name="android:background">?attr/colorSurfaceContainerLow</item>
    </style>
</resources>
