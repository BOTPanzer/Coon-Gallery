<!-- res/layout/home_header.xml -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="300dp"
    android:layout_marginBottom="2dp"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/image"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="bottom"
        android:orientation="vertical">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:alpha="1"
            app:srcCompat="@drawable/bg_gradient"
            app:tint="?attr/colorSurface" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:alpha=".6"
            app:srcCompat="@drawable/bg_gradient_reversed"
            app:tint="?attr/colorSurface" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="bottom|start"
        android:orientation="vertical">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:fontFamily="@font/opificio_bold_rounded"
            android:shadowColor="?attr/colorSurface"
            android:shadowRadius="10"
            android:text="Frogs"
            android:textColor="?attr/colorOnSurface"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="20dp"
            android:ellipsize="end"
            android:shadowColor="?attr/colorSurface"
            android:shadowRadius="10"
            android:singleLine="true"
            android:text="They are cool"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />
    </LinearLayout>

</RelativeLayout>